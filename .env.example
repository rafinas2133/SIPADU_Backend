# ── Server ────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000

# ── Database (Neon — production/Vercel) ───────────────────────────────────────
# Gunakan connection string pooled dari Neon dashboard:
DATABASE_URL=postgresql://neondb_owner:npg_Ar4GKthgjy7b@ep-odd-wildflower-aowgijm1-pooler.c-2.ap-southeast-1.aws.neon.tech/neondb?channel_binding=require&sslmode=require

# ── Database (lokal — development) ────────────────────────────────────────────
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=sipadu_cart
# DB_USER=postgres
# DB_PASSWORD=postgres

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_SECRET=change_this_to_a_very_long_random_secret_key
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change_this_refresh_secret_too_long_enough
JWT_REFRESH_EXPIRES_IN=7d

# ── Frontend ──────────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:5173

# ── Vercel Blob (production upload) ───────────────────────────────────────────
# BLOB_READ_WRITE_TOKEN=vercel_blob_rw_...

# ── Upload & Logs (lokal saja) ────────────────────────────────────────────────
UPLOAD_DIR=uploads
LOG_DIR=logs

# ── Rate Limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
